{
  "manifest_version": 3,
  "name": "Plain View",
  "version": "0.1.0",
  "description": "Plain View — friendly in-browser viewer for JSON, Markdown, SQL, YAML, CSV and LOG files.",

  "permissions": ["storage", "downloads"],

  "action": {
    "default_popup": "popup.html",
    "default_title": "Plain View"
  },

  "background": {
    "service_worker": "dist/background/index.js",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["dist/content/index.js"],
      "run_at": "document_end",
      "all_frames": false
    }
  ],

  "web_accessible_resources": [
    {
      "resources": [
        "dist/renderers/*.js",
        "dist/ui/*.js",
        "styles/*.css"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}
